# 🌐 GlobeVote Environment Configuration

# ── DATABASE ─────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/globevote

# ── OPENAI ───────────────────────────────────────────────────────────────
# Required for AI Civic Assistant and Claim Verification
OPENAI_API_KEY=sk-...

# Custom base URL (optional, defaults to official OpenAI API)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── SERVER ───────────────────────────────────────────────────────────────
# Secret for session management
SESSION_SECRET=a-long-random-string-here

# API Port (default: 8080)
PORT=8080

# ── FRONTEND ─────────────────────────────────────────────────────────────
# Public URL of the frontend (for CORS and redirects)
BASE_PATH=/
